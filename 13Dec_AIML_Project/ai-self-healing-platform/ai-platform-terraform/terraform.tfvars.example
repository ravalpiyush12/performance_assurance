# AWS Configuration
aws_region = "us-east-1"

# Project Settings
project_name = "ai-healing-platform"

# VPC Configuration
vpc_cidr = "10.0.0.0/16"

# EC2 Instance Configuration
# Ubuntu 22.04 LTS AMI for us-east-1
ami_id = "ami-0e86e20dae9224db8"

# Instance Types
master_instance_type = "t3.small"   # 2GB RAM - required for k3s + Prometheus
worker_instance_type = "t3.micro"   # 1GB RAM - free tier eligible

# k3s Cluster Token (change this for security)
k3s_token = "your-secure-k3s-cluster-token-here"

# SSH Key Paths
# IMPORTANT: Generate SSH key pair before running terraform
# Run: ssh-keygen -t rsa -b 4096 -f ~/.ssh/ai-healing-key
ssh_public_key_path  = "~/.ssh/ai-healing-key.pub"
ssh_private_key_path = "~/.ssh/ai-healing-key"
