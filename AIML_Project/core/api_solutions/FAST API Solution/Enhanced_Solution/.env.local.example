# Oracle SQL API - Multi-Database Configuration
# Copy this file to .env.local and update with your values

# ========================================
# Application Settings
# ========================================
APP_NAME=Oracle SQL API - Multi-Database
APP_VERSION=2.0.0
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# ========================================
# Global CyberArk Settings (for WRITE databases only)
# ========================================
CYBERARK_ENABLED=true
CYBERARK_URL=https://cyberark.example.com/AIMWebService/api/Accounts
CYBERARK_APP_ID=OracleSQLAPI
CYBERARK_CERT_PATH=/app/certs/client.crt
CYBERARK_CERT_KEY_PATH=/app/certs/client.key

# ========================================
# Audit Settings
# ========================================
ENABLE_AUDIT_LOG=true
AUDIT_LOG_PATH=./logs/audit

# ========================================
# SQL Execution Settings
# ========================================
MAX_SQL_FILE_SIZE_MB=10
SQL_EXECUTION_TIMEOUT=300
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# ========================================
# Database 1: CQE_NFT (Read/Write - DQL + DML - DIRECT AUTH)
# ========================================
CQE_NFT_HOST=cqe-nft-db.example.com
CQE_NFT_PORT=1521
CQE_NFT_SERVICE_NAME=CQENFT
CQE_NFT_USERNAME=cqe_user
CQE_NFT_PASSWORD=cqe_password_here
CQE_NFT_POOL_MIN=2
CQE_NFT_POOL_MAX=10
CQE_NFT_POOL_INCREMENT=1
# Generate with: openssl rand -hex 32
CQE_NFT_SECRET_KEY=your-cqe-nft-secret-key-256-bits-hex-string-here-64-characters-long
# Generate with: echo "apk_live_$(openssl rand -hex 20)"
CQE_NFT_API_KEYS=apk_live_cqe_nft_key1_40plus_chars,apk_live_cqe_nft_key2_40plus_chars

# ========================================
# Database 2: CD_PTE_READ (Read-only - DQL only - DIRECT AUTH)
# ========================================
CD_PTE_READ_HOST=cd-pte-db.example.com
CD_PTE_READ_PORT=1521
CD_PTE_READ_SERVICE_NAME=CDPTE
CD_PTE_READ_USERNAME=cd_read_user
CD_PTE_READ_PASSWORD=cd_read_password_here
CD_PTE_READ_POOL_MIN=2
CD_PTE_READ_POOL_MAX=10
CD_PTE_READ_POOL_INCREMENT=1
CD_PTE_READ_SECRET_KEY=your-cd-pte-read-secret-key-256-bits-hex-string-here-64-chars
CD_PTE_READ_API_KEYS=apk_live_cd_read_key1_40plus_chars,apk_live_cd_read_key2_40plus_chars

# ========================================
# Database 3: CD_PTE_WRITE (Write - DML only - CYBERARK)
# ========================================
CD_PTE_WRITE_HOST=cd-pte-db.example.com
CD_PTE_WRITE_PORT=1521
CD_PTE_WRITE_SERVICE_NAME=CDPTE
CD_PTE_WRITE_USERNAME=cd_write_user
CD_PTE_WRITE_PASSWORD=  # Leave empty - will use CyberArk
CD_PTE_WRITE_CYBERARK_SAFE=OracleDatabases
CD_PTE_WRITE_CYBERARK_OBJECT=CD_PTE_WRITE_Credentials
CD_PTE_WRITE_POOL_MIN=2
CD_PTE_WRITE_POOL_MAX=10
CD_PTE_WRITE_POOL_INCREMENT=1
CD_PTE_WRITE_SECRET_KEY=your-cd-pte-write-secret-key-256-bits-hex-string-here-64-chars
CD_PTE_WRITE_API_KEYS=apk_live_cd_write_key1_40plus_chars,apk_live_cd_write_key2_40plus_chars

# ========================================
# Database 4: CAS_PTE_READ (Read-only - DQL only - DIRECT AUTH)
# ========================================
CAS_PTE_READ_HOST=cas-pte-db.example.com
CAS_PTE_READ_PORT=1521
CAS_PTE_READ_SERVICE_NAME=CASPTE
CAS_PTE_READ_USERNAME=cas_read_user
CAS_PTE_READ_PASSWORD=cas_read_password_here
CAS_PTE_READ_POOL_MIN=2
CAS_PTE_READ_POOL_MAX=10
CAS_PTE_READ_POOL_INCREMENT=1
CAS_PTE_READ_SECRET_KEY=your-cas-pte-read-secret-key-256-bits-hex-string-here-64-chars
CAS_PTE_READ_API_KEYS=apk_live_cas_read_key1_40plus_chars,apk_live_cas_read_key2_40plus_chars

# ========================================
# Database 5: CAS_PTE_WRITE (Write - DML only - CYBERARK)
# ========================================
CAS_PTE_WRITE_HOST=cas-pte-db.example.com
CAS_PTE_WRITE_PORT=1521
CAS_PTE_WRITE_SERVICE_NAME=CASPTE
CAS_PTE_WRITE_USERNAME=cas_write_user
CAS_PTE_WRITE_PASSWORD=  # Leave empty - will use CyberArk
CAS_PTE_WRITE_CYBERARK_SAFE=OracleDatabases
CAS_PTE_WRITE_CYBERARK_OBJECT=CAS_PTE_WRITE_Credentials
CAS_PTE_WRITE_POOL_MIN=2
CAS_PTE_WRITE_POOL_MAX=10
CAS_PTE_WRITE_POOL_INCREMENT=1
CAS_PTE_WRITE_SECRET_KEY=your-cas-pte-write-secret-key-256-bits-hex-string-here-64-chars
CAS_PTE_WRITE_API_KEYS=apk_live_cas_write_key1_40plus_chars,apk_live_cas_write_key2_40plus_chars

# ========================================
# Database 6: PORTAL_PTE_READ (Read-only - DQL only - DIRECT AUTH)
# ========================================
PORTAL_PTE_READ_HOST=portal-pte-db.example.com
PORTAL_PTE_READ_PORT=1521
PORTAL_PTE_READ_SERVICE_NAME=PORTALPTE
PORTAL_PTE_READ_USERNAME=portal_read_user
PORTAL_PTE_READ_PASSWORD=portal_read_password_here
PORTAL_PTE_READ_POOL_MIN=2
PORTAL_PTE_READ_POOL_MAX=10
PORTAL_PTE_READ_POOL_INCREMENT=1
PORTAL_PTE_READ_SECRET_KEY=your-portal-pte-read-secret-key-256-bits-hex-string-here
PORTAL_PTE_READ_API_KEYS=apk_live_portal_read_key1_40plus_chars,apk_live_portal_read_key2

# ========================================
# Database 7: PORTAL_PTE_WRITE (Write - DML only - CYBERARK)
# ========================================
PORTAL_PTE_WRITE_HOST=portal-pte-db.example.com
PORTAL_PTE_WRITE_PORT=1521
PORTAL_PTE_WRITE_SERVICE_NAME=PORTALPTE
PORTAL_PTE_WRITE_USERNAME=portal_write_user
PORTAL_PTE_WRITE_PASSWORD=  # Leave empty - will use CyberArk
PORTAL_PTE_WRITE_CYBERARK_SAFE=OracleDatabases
PORTAL_PTE_WRITE_CYBERARK_OBJECT=PORTAL_PTE_WRITE_Credentials
PORTAL_PTE_WRITE_POOL_MIN=2
PORTAL_PTE_WRITE_POOL_MAX=10
PORTAL_PTE_WRITE_POOL_INCREMENT=1
PORTAL_PTE_WRITE_SECRET_KEY=your-portal-pte-write-secret-key-256-bits-hex-string-here
PORTAL_PTE_WRITE_API_KEYS=apk_live_portal_write_key1_40plus_chars,apk_live_portal_write

# ========================================
# QUICK START - Generate Production Keys
# ========================================
#
# Run these commands to generate secure keys:
#
# SECRET_KEY (64 hex characters):
#   openssl rand -hex 32
#
# API_KEY (40+ characters):
#   echo "apk_live_$(openssl rand -hex 20)"
#
# Example - Generate all keys at once:
#   for db in CQE_NFT CD_PTE_READ CD_PTE_WRITE CAS_PTE_READ CAS_PTE_WRITE PORTAL_PTE_READ PORTAL_PTE_WRITE; do
#     echo "${db}_SECRET_KEY=$(openssl rand -hex 32)"
#     echo "${db}_API_KEYS=apk_live_$(openssl rand -hex 20),apk_live_$(openssl rand -hex 20)"
#     echo ""
#   done

# =====================================================
# AppDynamics Monitoring Configuration
# Copy this to .env.local and update with your values
# =====================================================

# =====================================================
# AppDynamics Controller Configuration
# =====================================================
APPD_CONTROLLER_HOST=controller.appdynamics.com
APPD_CONTROLLER_PORT=443
APPD_ACCOUNT_NAME=customer1
APPD_USERNAME=admin@customer1
APPD_PASSWORD=your_password_here
APPD_USE_SSL=true

# =====================================================
# API Configuration
# =====================================================
APPD_API_TIMEOUT=30
APPD_MAX_RETRIES=3

# =====================================================
# Discovery Configuration
# =====================================================
APPD_ACTIVE_NODE_CPM_THRESHOLD=10
APPD_DISCOVERY_SCHEDULE=DAILY
APPD_DISCOVERY_LOOKBACK_MINUTES=30

# =====================================================
# Monitoring Configuration
# =====================================================
APPD_COLLECTION_INTERVAL_SECONDS=1800
APPD_MAX_CONCURRENT_MONITORS=10
APPD_METRICS_BATCH_SIZE=100

# =====================================================
# Thread Pool Configuration
# =====================================================
APPD_THREAD_POOL_SIZE_PER_TIER=5
APPD_THREAD_TIMEOUT_SECONDS=300

# =====================================================
# Metric Collection Flags
# =====================================================
APPD_COLLECT_SERVER_METRICS=true
APPD_COLLECT_JVM_METRICS=true
APPD_COLLECT_APP_METRICS=true
